# Base de datos PostgreSQL (Vercel Postgres o cualquier Postgres)
# Obtén una URL en: https://vercel.com/storage/postgres
POSTGRES_URL="postgres://usuario:password@host:5432/database?sslmode=require"

# NextAuth - secreto para firmar tokens (genera uno con: openssl rand -base64 32)
AUTH_SECRET="tu-secreto-aqui"

# Server Actions: clave estable para evitar "Failed to fetch" (genera con: openssl rand -base64 32)
# NEXT_SERVER_ACTIONS_ENCRYPTION_KEY="tu-clave-base64-32"
# URL base de la app (para enlaces de recuperación de contraseña). En Vercel se usa NEXTAUTH_URL
# APP_URL="http://localhost:3000"

# Protección de APIs internas (obligatorios en local y Vercel; genera con: openssl rand -base64 32)
# Vercel Cron envía automáticamente: Authorization: Bearer <CRON_SECRET>
# En local: curl -H "Authorization: Bearer <CRON_SECRET>" http://localhost:3000/api/cron
CRON_SECRET="tu-secreto-cron"
SEED_SECRET="tu-secreto-seed"
DB_CHECK_SECRET="tu-secreto-db-check"

# Email del reporte diario (/api/cron). Si no se define, usa el email del primer admin.
# REPORT_EMAIL="admin@tuempresa.com"

# SMTP para reportes (opcional; si no se configura, usa Ethereal en desarrollo)
# SMTP_HOST="smtp.ejemplo.com"
# SMTP_PORT="587"
# SMTP_USER="user"
# SMTP_PASS="pass"
